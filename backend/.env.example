# =========================
# FastAPI basic config
# =========================
APP_NAME=Study Focus API
DEBUG=true
API_V1_PREFIX=/api/v1

# JWT config
SECRET_KEY=PLEASE_CHANGE_ME_TO_A_RANDOM_LONG_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=120
ALGORITHM=HS256

# CORS allow list (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MySQL config
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=CHANGE_ME
MYSQL_DB=study_focus
DB_ECHO=false

# AI config
# Provider options: openai_compatible | anthropic_compatible
AI_PROVIDER=anthropic_compatible

# For openai_compatible, use something like https://api.openai.com/v1
# For anthropic_compatible (ModelScope), use https://api-inference.modelscope.cn
AI_API_BASE=https://api-inference.modelscope.cn

# Either AI_API_KEY or ANTHROPIC_AUTH_TOKEN can be used
AI_API_KEY=YOUR_API_KEY
ANTHROPIC_AUTH_TOKEN=

# Example models:
# - gpt-4o-mini (OpenAI)
# - ZhipuAI/GLM-5 (ModelScope)
AI_MODEL=ZhipuAI/GLM-5
